# Local development only. Set these values in Render's Environment page for production.
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/futuresim?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
# Comma-separated URLs are supported. Include your Vercel production URL in Render.
CLIENT_ORIGIN=http://localhost:5173
# Optional: enables Gemini-generated responses. The rules engine works without it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash